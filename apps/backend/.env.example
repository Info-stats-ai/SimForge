# SimForge Backend Environment
APP_ENV=development
DATABASE_URL=sqlite:///./simforge.db
REDIS_URL=redis://localhost:6379/0
STORAGE_ROOT=./storage
SIMULATION_PROVIDER=mock
SECRET_KEY=simforge-dev-secret-change-in-production

# HPC / Isaac Sim (optional — only needed for real simulation)
HPC_HOST=
HPC_USER=
HPC_WORKDIR=/scratch/simforge
ISAAC_RESULTS_DIR=/scratch/simforge/results
