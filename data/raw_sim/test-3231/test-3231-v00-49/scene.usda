#usda 1.0
(
    defaultPrim = "World"
)

def Xform "World"
{
    customData = {
        string simforge:job_id = "test-3231"
        string simforge:scenario_id = "test-3231-v00-49"
    }
    def Xform "WarehouseEnvironment" {
        custom string preset = "loading_zone"
        custom string lighting = "poor"
    }
    def Xform "Robot" { custom string kind = "mobile_robot" }
    def Xform "Pedestrians" {
        custom int count = 3
    }
    def Xform "Forklifts" {
        custom int count = 0
    }
    def Xform "Sensors" {
        def Xform "PreviewCamera" { custom string purpose = "preview" }
        def Xform "LidarMount" { custom string purpose = "future_sensor" }
    }
}